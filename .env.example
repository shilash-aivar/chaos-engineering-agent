# API
CHAOS_AGENT_ENV=development
CHAOS_AGENT_HOST=0.0.0.0
CHAOS_AGENT_PORT=8000
CHAOS_AGENT_LOG_LEVEL=INFO

# Database (SQLite default for local dev)
DATABASE_URL=sqlite+aiosqlite:///./chaos_agent.db

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CHAOS_AGENT_USE_CELERY=false
CHAOS_AGENT_CELERY_LONG_DURATION_MINUTES=10
CHAOS_AGENT_CELERY_BROKER_URL=redis://localhost:6379/1

# LLM (Composer, Remediator, Red, Blue agents)
CHAOS_AGENT_ANTHROPIC_API_KEY=
CHAOS_AGENT_ANTHROPIC_MODEL=claude-sonnet-4-20250514
CHAOS_AGENT_LLM_ENABLED=true
CHAOS_AGENT_AUTO_REMEDIATE_ON_COMPLETE=true
CHAOS_AGENT_INJECT_RED_BLUE_FAULTS=true

# Kubernetes
KUBECONFIG=
CHAOS_DEFAULT_NAMESPACE=staging

# AWS
AWS_PROFILE=
AWS_REGION=us-east-1

# Observability targets
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000
LOKI_URL=http://localhost:3100
TEMPO_URL=http://localhost:3200
TOXIPROXY_URL=http://localhost:8474

# Observability + remediation integrations
PAGERDUTY_API_KEY=
CHAOS_AGENT_GITHUB_TOKEN=
CHAOS_AGENT_GITHUB_ORG=
CHAOS_AGENT_GITHUB_REPO=
CHAOS_AGENT_GITHUB_DEFAULT_BRANCH=main
CHAOS_AGENT_STAGING_BASE_URL=http://localhost:8080
CHAOS_AGENT_AUTO_VERIFY_REMEDIATION=false
CHAOS_AGENT_AWS_FIS_ENABLED=false
CHAOS_AGENT_EBPF_ENABLED=true
CHAOS_AGENT_EBPF_USE_TC=false
CHAOS_AGENT_WASM_PLUGINS_ENABLED=true
CHAOS_AGENT_WASM_PLUGINS_DIR=plugins/wasm
CHAOS_AGENT_API_KEY=
# Frontend — set when CHAOS_AGENT_API_KEY is enabled (Vite exposes VITE_* at build time)
VITE_CHAOS_AGENT_API_KEY=
CHAOS_AGENT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CHAOS_AGENT_DEMO_MODE=false
CHAOS_AGENT_SEED_DATA=false
CHAOS_AGENT_RATE_LIMIT_PER_MINUTE=120
CHAOS_AGENT_K8S_LOAD_TEST_IMAGE=grafana/k6:latest
CHAOS_AGENT_API_PUBLIC_URL=http://127.0.0.1:8000
CHAOS_AGENT_SLACK_WEBHOOK_URL=
CHAOS_AGENT_SLACK_BOT_TOKEN=
CHAOS_AGENT_SLACK_APPROVAL_CHANNEL=#chaos-agent-approvals

# Safety
CHAOS_ALLOW_PROD=false
CHAOS_MAX_REPLICA_PERCENT=30
CHAOS_SIMULATE_EXECUTION=false
CHAOS_STEADY_STATE_ERROR_MULTIPLIER=2.0
CHAOS_STEADY_STATE_LATENCY_MULTIPLIER=3.0
CHAOS_GUARD_INTERVAL_SECONDS=15
CHAOS_EXPERIMENT_MAX_DURATION_SECONDS=180
