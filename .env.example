# API
CHAOS_AGENT_ENV=development
CHAOS_AGENT_HOST=0.0.0.0
CHAOS_AGENT_PORT=8000
CHAOS_AGENT_LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://chaos:chaos@localhost:5432/chaos_agent

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# LLM
ANTHROPIC_API_KEY=

# Kubernetes (uses kubeconfig or in-cluster)
KUBECONFIG=
CHAOS_DEFAULT_NAMESPACE=staging

# AWS (uses AWS profile or env credentials)
AWS_PROFILE=
AWS_REGION=us-east-1

# Observability
PROMETHEUS_URL=http://localhost:9090

# Integrations
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
GITHUB_TOKEN=
GITHUB_ORG=
GITHUB_REPO=

# Safety
CHAOS_ALLOW_PROD=false
CHAOS_MAX_REPLICA_PERCENT=30
CHAOS_STEADY_STATE_ERROR_MULTIPLIER=2.0
CHAOS_STEADY_STATE_LATENCY_MULTIPLIER=3.0
